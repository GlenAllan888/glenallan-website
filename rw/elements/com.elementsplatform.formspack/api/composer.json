{
    "name": "realmac/elements-forms-api",
    "description": "Minimal PHP API for RapidWeaver Elements form submissions (email and webhook)",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.6",
        "nyholm/psr7": "^1.5",
        "nyholm/psr7-server": "^1.0",
        "phpmailer/phpmailer": "^6.9",
        "guzzlehttp/guzzle": "^7.0",
        "monolog/monolog": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080"
    }
}

